---
import BlogPost from '../../components/BlogPost.astro';
import '../../styles/global.css';
import { baseUrl, fetchUrl, getTags } from '../../api/drupal.ts';
import type { DrupalNode, Tags, DrupalImage } from '../../types';
import {getArticles} from "../../api/drupal.ts";
declare module '../../layouts/BlogPost.astro';

   
export function getHeadingsAndBookmarkedBody(body: string) {
  const headingRegex = /<(h[23])\b([^>]*)>([\s\S]*?)<\/\1>/gi;
  const slugCounts = new Map<string, number>();
  const headings: Array<{ depth: number; text: string; slug: string }> = [];
  const html = body.replace(headingRegex, (full, tag, attrText, content) => {
    const text = stripHtml(content).replace(/\s+/g, ' ').trim();
    if (!text) return full;

    const explicitIdMatch = attrText.match(/\sid=(?:"([^"]*)"|'([^']*)'|([^>\s]+))/i);
    const explicitId = explicitIdMatch ? explicitIdMatch[1] || explicitIdMatch[2] || explicitIdMatch[3] : undefined;
    let slug = explicitId ?? slugify(text);

    const count = slugCounts.get(slug) ?? 0;
    slugCounts.set(slug, count + 1);
    if (count > 0) slug = `${slug}-${count + 1}`;

    const depth = tag === 'h2' ? 2 : 3;
    headings.push({ depth, text, slug });

    const idAttr = explicitId ? '' : ` id="${slug}"`;
    return `<${tag}${attrText}${idAttr}>${content}</${tag}>`;
  });

  return { headings, bodyWithBookmarks: html };
}

export function stripHtml(html: string) {
  return html.replace(/<[^>]+>/g, '').trim();
}

export function slugify(text: string) {
  return text
    .toLowerCase()
    .replace(/<[^>]+>/g, '')
    .replace(/[^\w\s-]/g, '')
    .replace(/\s+/g, '-')
    .replace(/-+/g, '-')
    .replace(/^-|-$/g, '');
}

export function getTagNamesById(
  tt: Tags[],
  taglist: Array<{ tagid?: string | number; target_id?: string | number; id?: string | number } | undefined> | undefined,
): string[] {
  if (!Array.isArray(tt) || !Array.isArray(taglist)) {
    return [];
  }

  const tagIds = new Set(
    taglist
      .map((tag) => String(tag?.tagid ?? tag?.target_id ?? tag?.id ?? ''))
      .filter((id) => id.length > 0),
  );

  return tt
    .filter((tag) => tagIds.has(String(tag?.id ?? tag?.target_id ?? tag?.tagid ?? '')))
    .map((tag) => tag.name)
    .filter((name): name is string => typeof name === 'string' && name.length > 0);
}



export async function getStaticPaths() {
    const articles = await getArticles();
    const tt = await getTags();

    return articles.map((article: DrupalNode) => {
      // Construct the formatted body 
      const { headings, bodyWithBookmarks } = getHeadingsAndBookmarkedBody(article.body.value);
      // Decode the tag list
      const tagNames = getTagNamesById(tt, article.field_tags);
      const d_URL = baseUrl + 'jsonapi/node/file-file/'+ article.field_image?.id;

      return {
          params: {
              // Choose `path` to match the `[path]` routing value
              slug: article.path.alias
          },
          props: {
              title: article.title,
              Taglist: tagNames,
              Body: bodyWithBookmarks,
              hero_url: d_URL,
              hero_alt: article.field_image?.resourceIdObjMeta.alt,
              Headings: headings,
              Description: article.summary,
              created: new Date(article.created).toLocaleDateString('en-AU', {
                  day: "numeric",
                  month: "long",
                  year: "numeric"
              })
          }
        }
      });
}

const {title, created, Body, Description, Taglist, Headings, hero_url , hero_alt} = Astro.props;
---

<BlogPost title={title} publishDate={created} description={Description} taglist={Taglist} headings={Headings} hero_url={hero_url} hero_alt={hero_alt} >
  <div set:html={Body} />
</BlogPost>



