---
import BlogPost from '../../layouts/BlogPost.astro';
import '../../styles/global.css';
import { baseUrl, fetchUrl, getTags } from '../../api/drupal';
import type { DrupalNode, Tags } from '../../types';
import type { string } from 'astro:schema';
export const prerender = false;

const { slug } = Astro.params;

// Fetch the specific article from Drupal using a JSON:API filter
const drupalUrl = baseUrl + '/jsonapi/node/risk_article';
const response = await fetchUrl(drupalUrl) as DrupalNode[];

// Handle 404 if the article doesn't exist in Drupal
if (!response ) {
  return Astro.redirect('/404');
}

// Extract the article data
const post = response.find(a => a.path.alias == "/"+slug) as DrupalNode;
const { headings, bodyWithBookmarks } = getHeadingsAndBookmarkedBody(post.body.value);

function getHeadingsAndBookmarkedBody(body: string) {
  const headingRegex = /<(h[23])\b([^>]*)>([\s\S]*?)<\/\1>/gi;
  const slugCounts = new Map<string, number>();
  const headings: Array<{ depth: number; text: string; slug: string }> = [];

  const html = body.replace(headingRegex, (full, tag, attrText, content) => {
    const text = stripHtml(content).replace(/\s+/g, ' ').trim();
    if (!text) return full;

    const explicitIdMatch = attrText.match(/\sid=(?:"([^"]*)"|'([^']*)'|([^>\s]+))/i);
    const explicitId = explicitIdMatch ? explicitIdMatch[1] || explicitIdMatch[2] || explicitIdMatch[3] : undefined;
    let slug = explicitId ?? slugify(text);

    const count = slugCounts.get(slug) ?? 0;
    slugCounts.set(slug, count + 1);
    if (count > 0) slug = `${slug}-${count + 1}`;

    const depth = tag === 'h2' ? 2 : 3;
    headings.push({ depth, text, slug });

    const idAttr = explicitId ? '' : ` id="${slug}"`;
    return `<${tag}${attrText}${idAttr}>${content}</${tag}>`;
  });

  return { headings, bodyWithBookmarks: html };
}

function stripHtml(html: string) {
  return html.replace(/<[^>]+>/g, '').trim();
}

function slugify(text: string) {
  return text
    .toLowerCase()
    .replace(/<[^>]+>/g, '')
    .replace(/[^\w\s-]/g, '')
    .replace(/\s+/g, '-')
    .replace(/-+/g, '-')
    .replace(/^-|-$/g, '');
}

function getTagNamesById(
  tt: Tags[],
  taglist: Array<{ tagid?: string | number; target_id?: string | number; id?: string | number } | undefined> | undefined,
): string[] {
  if (!Array.isArray(tt) || !Array.isArray(taglist)) {
    return [];
  }

  const tagIds = new Set(
    taglist
      .map((tag) => String(tag?.tagid ?? tag?.target_id ?? tag?.id ?? ''))
      .filter((id) => id.length > 0),
  );

  return tt
    .filter((tag) => tagIds.has(String(tag?.id ?? tag?.target_id ?? tag?.tagid ?? '')))
    .map((tag) => tag.name)
    .filter((name): name is string => typeof name === 'string' && name.length > 0);
}

// Decode the tag list
const tt = await getTags();
const tagNames = getTagNamesById(tt, post.field_tags);

---

<BlogPost title={post.title} publishDate={post.created} description={post.summary} taglist={tagNames} headings={headings} >
  <div set:html={bodyWithBookmarks} />
</BlogPost>



