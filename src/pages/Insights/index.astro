---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/footer.astro';
import Header from '../../components/header.astro';
import ImageCard from '../../components/imageCard.astro';
import type { DrupalNode, Tags } from "../../types";
import {getArticles} from "../../api/drupal.ts";
import "../../styles/global.css";
import dayjs from 'dayjs';


// Get all published articles.
const allPosts = await getArticles();
const sortedPosts = allPosts.toSorted((a, b) => new Date(b.created) - new Date(a.created));
const groupedPosts = allPosts.reduce((acc: any, post: DrupalNode) => {
	const year = post.created.toString().slice(0, 4);
	if (!acc[year]) {
		acc[year] = [];
	}
	acc[year].push(post);
	return acc;
}, {} as Record<string, typeof allPosts>);

const sortedYears = Object.keys(groupedPosts).sort((a, b) => parseInt(b) - parseInt(a));

---
<Layout pageTitle="Risk Insights">
<Header />

 <!-- Page: Risk Insights -->
 <blog_header class="mb-16 text-center">
    <h1 class="text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl">Risk Insights</h1>
    <p class="mt-4 text-lg text-slate-600">Rivet Risk hears from many small businesses just like yours. Learn how they are making their future safer.</p>
  </blog_header>

<main class="grow">
<!-- Article Grid -->
 <div class="mx-auto mt-12 grid max-w-2xl grid-cols-1 gap-x-8 gap-y-16 border-t border-gray-200 pt-10 sm:mt-16 sm:pt-16 lg:max-w-none lg:grid-cols-3">
	<!-- Card 1 -->
	<blogcard class="flex flex-col overflow-hidden rounded-2xl bg-white shadow-md ring-1 ring-slate-200 duration-200 hover:-translate-y-1 hover:shadow-xl">
      <div class="relative aspect-[16/10] w-full overflow-hidden bg-slate-100">
         <ImageCard imagePath = {'/src/assets/' + sortedPosts[0].field_hero_image_tag} altText={sortedPosts[0].field_imagealt} />
      </div>
      <div class="flex flex-1 flex-col p-6">
        <div class="flex items-center gap-2 text-xs">
          <time datetime="20 June 2026" class="text-slate-500">{dayjs(sortedPosts[0].created).format('DD MMM YYYY')}</time>
          <span class="rounded-full bg-slate-100 px-2 py-1 font-medium text-slate-600">Design</span>
        </div>
        <h3 class="mt-3 text-xl font-semibold text-slate-900">
          <a href={'.'+sortedPosts[0].path.alias} class="stretched-link hover:text-indigo-600">{sortedPosts[0].title}</a>
        </h3>
        <p class="mt-2 text-sm text-slate-600 line-clamp-2">{sortedPosts[0].field_seo_description}</p>
      </div>
	</blogcard>

	<!-- Card 2 -->
	<blogcard class="flex flex-col overflow-hidden rounded-2xl bg-white shadow-md ring-1 ring-slate-200 duration-200 hover:-translate-y-1 hover:shadow-xl">
      <div class="relative aspect-[16/10] w-full overflow-hidden bg-slate-100">
        <ImageCard imagePath = {'/src/assets/' + sortedPosts[1].field_hero_image_tag} altText={sortedPosts[1].field_imagealt} />
      </div>
      <div class="flex flex-1 flex-col p-6">
        <div class="flex items-center gap-2 text-xs">
          <time datetime="20 June 2026" class="text-slate-500">{dayjs(sortedPosts[1].created).format('DD MMM YYYY')}</time>
          <span class="rounded-full bg-slate-100 px-2 py-1 font-medium text-slate-600">Design</span>
        </div>
        <h3 class="mt-3 text-xl font-semibold text-slate-900">
          <a href={'.'+sortedPosts[1].path.alias} class="stretched-link hover:text-indigo-600">{sortedPosts[1].title}</a>
        </h3>
        <p class="mt-2 text-sm text-slate-600 line-clamp-2">{sortedPosts[1].field_seo_description}</p>
      </div>
	</blogcard>

	<!-- Card 3 -->
	<blogcard class="flex flex-col overflow-hidden rounded-2xl bg-white shadow-md ring-1 ring-slate-200 duration-200 hover:-translate-y-1 hover:shadow-xl">
      <div class="relative aspect-[16/10] w-full overflow-hidden bg-slate-100">
       <ImageCard imagePath = {'/src/assets/' + sortedPosts[2].field_hero_image_tag} altText={sortedPosts[2].field_imagealt} />
      </div>
      <div class="flex flex-1 flex-col p-6">
        <div class="flex items-center gap-2 text-xs">
          <time datetime="20 June 2026" class="text-slate-500">{dayjs(sortedPosts[2].created).format('DD MMM YYYY')}</time>
          <span class="rounded-full bg-slate-100 px-2 py-1 font-medium text-slate-600">Design</span>
        </div>
        <h3 class="mt-3 text-xl font-semibold text-slate-900">
          <a href={'.'+sortedPosts[2].path.alias} class="stretched-link hover:text-indigo-600">{sortedPosts[2].title}</a>
        </h3>
        <p class="mt-2 text-sm text-slate-600 line-clamp-2">{sortedPosts[2].field_seo_description}</p>
      </div>
	</blogcard>
 </div>
 
</main>
<Footer />
</Layout>

<style>
	main {
		max-width: 80%;
		margin: 0 auto;
		padding: var(--space-10) var(--space-5) var(--space-12);
	}
	.archive-container {
		line-height: 1.8;
	}
	.year-section {
		margin-bottom: var(--space-8);
	}
	.year-title {
		font-size: 2.5rem;
		font-weight: 700;
		color: var(--color-navy);
		margin: 0 0 var(--space-4) 0;
		display: flex;
		align-items: center;
		gap: var(--space-3);
	}
	.year-title::before {
		content: '';
		width: 4px;
		height: 1.25rem;
		background: linear-gradient(180deg, var(--accent), #8b5cf6);
		border-radius: 2px;
	}
	.year-count {
		font-size: 0.8rem;
		font-weight: 400;
		color: var(--text-muted);
		background: var(--bg-secondary);
		padding: 0.25rem 0.5rem;
		border-radius: 9999px;
	}
	.post-list {
		list-style-type: none;
		margin: 0;
		padding: 0;
	}
	.post-item {
		padding: 0.375rem 0;
		border-radius: 0.375rem;
		transition: background 0.2s ease;
	}
	.post-item:hover {
		background: rgba(249, 115, 22, 0.08);
	}
	.post-link {
		display: flex;
		align-items: baseline;
		gap: var(--space-5);
		text-decoration: none;
		color: inherit;
		padding: var(--space-1-5) var(--space-2);
		border-radius: 0.375rem;
		transition: color 0.2s ease;
	}
	.post-link:hover {
		color: var(--burnt-orange);
	}
	.post-date {
		font-size: 0.85rem;
		color: var(--text-muted);
		min-width: 80px;
		flex-shrink: 0;
	}
	.post-title {
		font-size: 1rem;
		font-weight: 500;
		margin: 0;
		color: var(--text-primary);
		flex: 1;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}
	.post-tags {
		display: flex;
		gap: var(--space-1-5);
		flex-wrap: wrap;
		flex-shrink: 0;
	}
	.post-tag {
		font-size: 0.7rem;
		color: var(--text-muted);
		padding: 0.125rem 0.375rem;
		background: var(--bg-secondary);
		border-radius: 0.25rem;
	}
	.load-more {
		display: flex;
		justify-content: center;
		margin-top: var(--space-8);
		padding-top: var(--space-6);
		border-top: 1px solid var(--border-color);
	}
	.load-more-btn {
		display: inline-flex;
		align-items: center;
		gap: var(--space-2);
		padding: var(--space-3) var(--space-6);
		background: var(--bg-secondary);
		border: 1px solid var(--border-color);
		border-radius: 8px;
		color: var(--text-primary);
		font-size: 0.9rem;
		font-weight: 500;
		cursor: pointer;
		transition: all 0.2s ease;
	}
	.load-more-btn:hover {
		background: var(--accent);
		color: white;
		border-color: var(--accent);
	}
	.load-more-btn:disabled {
		opacity: 0.5;
		cursor: not-allowed;
	}
	.loading-spinner {
		width: 16px;
		height: 16px;
		border: 2px solid currentColor;
		border-top-color: transparent;
		border-radius: 50%;
		animation: spin 0.8s linear infinite;
	}
	@keyframes spin {
		to { transform: rotate(360deg); }
	}
	@media (max-width: 720px) {
		main {
			width: 100%;
			padding: 0 var(--space-4);
		}
		.post-link {
			flex-direction: column;
			gap: 0.25rem;
			align-items: flex-start;
		}
		.post-date {
			min-width: auto;
		}
		.post-title {
			white-space: normal;
			overflow: visible;
			text-overflow: unset;
		}
	}
	
</style>
