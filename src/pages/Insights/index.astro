---
import "../../styles/global.css";
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/footer.astro';
import Header from '../../components/header.astro';
import type { DrupalNode, Tags } from "../../types";
import {getArticles} from "../../api/drupal";

// Get all published articles.
const allPosts = await getArticles();
const groupedPosts = allPosts.reduce((acc: any, post: DrupalNode) => {
	const year = post.created.toString().slice(0, 4);
	if (!acc[year]) {
		acc[year] = [];
	}
	acc[year].push(post);
	return acc;
}, {} as Record<string, typeof allPosts>);

const sortedYears = Object.keys(groupedPosts).sort((a, b) => parseInt(b) - parseInt(a));

const formatDate = (date: string) => {
	const month = date.slice(5, 7).padStart(2, '0');
	const day = date.slice(8, 10).padStart(2, '0');
	return `${month}-${day}`;
};

---
<Layout pageTitle="Risk Insights">
<Header />
 <!-- Page: Risk Insights -->
<div class="text-left pl-40">
	<h1 class="text-4xl font-extrabold text-rivet-navy mb-4">Risk Insights</h1>
	<p class="text-xl text-steel-blue max-w-3xl">Rivet Risk hears from many small businesses like just like yours. Learn how they are making their future safer.</p>
</div>
<main>
		<section class="archive-container">
		{
			sortedYears.map((year: string) => (
				<div class="year-section" id={`year-${year}`} key={year}>
					<h2 class="year-title">
						{year}
						<span class="year-count">{groupedPosts[year].length} posts</span>
					</h2>
					<ul class="post-list">
						{
							groupedPosts[year].map((post: DrupalNode) => (
								<li class="post-item" >
									<a href={`.${post.path.alias}`}  class="post-link"> 
										<span class="post-date">{post.created.toString().slice(4,10)}</span>
										<h3 class="post-title">{post.title}</h3>
										{post.articletaglist && post.articletaglist.length > 0 && (
											<div class="post-tags">
												{post.articletaglist.slice(0, 3).map((onetag: any) => (<span class="post-tag">#{onetag}</span>
												))}
												{post.articletaglist.length > 3 && (
														<span class="post-tag">...{post.articletaglist.length - 3}</span>
													)}
											</div>
										)}
									</a>
								</li>
							))
						}
					</ul>
				</div>
			))
		}
	</section>
</main>
<Footer />
</Layout>

<style>
	main {
		max-width: 80%;
		margin: 0 auto;
		padding: 2rem 1.25rem 4rem;
	}
	.archive-container {
		line-height: 1.8;
	}
	.year-section {
		margin-bottom: 2rem;
	}
	.year-title {
		font-size: 1.25rem;
		font-weight: 700;
		margin: 0 0 1rem 0;
	
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}
	.year-title::before {
		content: '';
		width: 4px;
		height: 1.25rem;
		background: linear-gradient(180deg, var(--accent), #8b5cf6);
		border-radius: 2px;
	}
	.year-count {
		font-size: 0.8rem;
		font-weight: 400;
		color: var(--text-muted);
		background: var(--bg-secondary);
		padding: 0.25rem 0.5rem;
		border-radius: 9999px;
	}
	.post-list {
		list-style-type: none;
		margin: 0;
		padding: 0;
	}
	.post-item {
		padding: 0.375rem 0;
		border-radius: 0.375rem;
		transition: background 0.2s ease;
	}
	.post-item:hover {
		background: rgba(249, 115, 22, 0.08);
	}
	.post-link {
		display: flex;
		align-items: baseline;
		gap: 1.25rem;
		text-decoration: none;
		color: inherit;
		padding: 0.375rem 0.5rem;
		border-radius: 0.375rem;
		transition: color 0.2s ease;
	}
	.post-link:hover {
		color: var(--burnt-orange);
	}
	.post-date {
		font-size: 0.85rem;
		color: var(--text-muted);
		min-width: 80px;
		flex-shrink: 0;
	}
	.post-title {
		font-size: 1rem;
		font-weight: 500;
		margin: 0;
		color: var(--text-primary);
		flex: 1;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}
	.post-tags {
		display: flex;
		gap: 0.375rem;
		flex-wrap: wrap;
		flex-shrink: 0;
	}
	.post-tag {
		font-size: 0.7rem;
		color: var(--text-muted);
		padding: 0.125rem 0.375rem;
		background: var(--bg-secondary);
		border-radius: 0.25rem;
	}
	.load-more {
		display: flex;
		justify-content: center;
		margin-top: 2rem;
		padding-top: 1.5rem;
		border-top: 1px solid var(--border-color);
	}
	.load-more-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.75rem 1.5rem;
		background: var(--bg-secondary);
		border: 1px solid var(--border-color);
		border-radius: 8px;
		color: var(--text-primary);
		font-size: 0.9rem;
		font-weight: 500;
		cursor: pointer;
		transition: all 0.2s ease;
	}
	.load-more-btn:hover {
		background: var(--accent);
		color: white;
		border-color: var(--accent);
	}
	.load-more-btn:disabled {
		opacity: 0.5;
		cursor: not-allowed;
	}
	.loading-spinner {
		width: 16px;
		height: 16px;
		border: 2px solid currentColor;
		border-top-color: transparent;
		border-radius: 50%;
		animation: spin 0.8s linear infinite;
	}
	@keyframes spin {
		to { transform: rotate(360deg); }
	}
	@media (max-width: 720px) {
		main {
			width: 100%;
			padding: 0 1rem;
		}
		.post-link {
			flex-direction: column;
			gap: 0.25rem;
			align-items: flex-start;
		}
		.post-date {
			min-width: auto;
		}
		.post-title {
			white-space: normal;
			overflow: visible;
			text-overflow: unset;
		}
	}
	html.dark .year-title {
		color: var(--accent);
	}
	html.dark .year-title::before {
		background: linear-gradient(180deg, var(--accent), #FDBA74);
	}
	html.dark .year-count {
		background: var(--bg-secondary);
		color: var(--text-muted);
	}
	html.dark .post-link:hover {
		color: var(--accent);
	}
	html.dark .post-item:hover {
		background: rgba(251, 146, 60, 0.15);
	}
	html.dark .post-title {
		color: var(--text-primary);
	}
	html.dark .post-tag {
		background: var(--bg-secondary);
	}
	html.dark .load-more-btn {
		background: var(--bg-secondary);
		border-color: var(--border-color);
		color: var(--text-primary);
	}
	html.dark .load-more-btn:hover {
		background: var(--accent);
		color: white;
	}
</style>
