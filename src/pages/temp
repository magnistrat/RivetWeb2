     <form id="contact-form">
        
        <div class="form-group">
          <label for="name">Name</label>
          <input type="text" id="name" name="name" required />
        </div>

        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required />
        </div>

        <div class="form-group">
          <label for="subject">Subject</label>
          <input type="text" id="subject" name="subject" required />
        </div>

        <div class="form-group">
          <label for="message">Message</label>
          <textarea id="message" name="message" rows="5" required></textarea>
        </div>

        <Button type="submit">Send</button>
      </form>
 

      <style>
    .form-group { margin-bottom: 1rem; }
    .form-group label { display: block; margin-bottom: 0.5rem; font-weight: bold;}
    .form-group input, .form-group textarea { width: 100%; padding: 0.5rem; border: 1px solid #ccc; border-radius: 4px; }
    /* The honeypot field is hidden from real users but visible to screen-reading bots */
    .visually-hidden { position: absolute; left: -10000px; top: auto; width: 1px; height: 1px; overflow: hidden; }
    .status-message { margin-top: 1rem; padding: 1rem; border-radius: 4px; display: block; }
    .status-message.error { background: #f8d7da; color: #721c24; }
    .success-msg { background: #d4edda; color: #155724; display: block; margin-top: 1rem; padding: 1rem; border-radius: 4px; }
</style>

<script>
  import { actions, isInputError } from 'astro:actions';
  import { navigate } from 'astro:transitions/client';

const form = document.querySelector('form');
const formData = new FormData(form);
const { error } = await actions.sendContactForm(formData);
if (isInputError(error)) {
  // Handle input errors.
  if (error.fields.email) {
    const message = error.fields.email.join(', ');
  }
 }
</script>



<script>
  const form = document.getElementById('send-form');
  const btn = document.getElementById('submit-btn');
  const resultDiv = document.getElementById('result');
  
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.disabled = true;
    btn.textContent = 'Sending...';
    resultDiv.style.display = 'none';

    const to = (document.getElementById('to')).value;
    const subject = (document.getElementById('subject')).value;
    const message = (document.getElementById('message')).value;

    try {
      const response = await fetch('/api/send', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ to, subject, message }),
      });

      const data = await response.json();
      resultDiv.style.display = 'block';

      if (!response.ok) {
        resultDiv.className = 'result error';
        resultDiv.textContent = data.error || 'Failed to send email';
      } else {
        resultDiv.className = 'result success';
        resultDiv.innerHTML = '<strong>Email sent successfully!</strong><br/>ID:'' ${data.id};
      }
    } catch {
      resultDiv.style.display = 'block';
      resultDiv.className = 'result error';
      resultDiv.textContent = 'Network error. Please try again.';
    } finally {
      btn.disabled = false;
      btn.textContent = 'Send Email';
    }
  });
</script>