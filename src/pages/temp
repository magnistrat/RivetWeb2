<Layout pageTitle={post.title}>
 <Header />
  <section id="about" class="page-section">
    <div class="bg-white rounded-lg shadow-xl p-8 md:p-12">
        <h1 class="text-4xl font-extrabold text-rivet-navy mb-6">{post.title}</h1> 
        <div class="flex flex-col md:flex-row gap-8">
            <div class="md:w-2/3 space-y-4 text-lg text-steel-blue">
                <p><em>{formatDate(post.publishDate)}</em></p>
                <Content />
            </div>
        </div>
    </div>
    </section>
    <Footer />
</Layout>
