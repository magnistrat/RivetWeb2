---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/footer.astro";
import Header from "../components/header.astro";
import {Image} from 'astro:assets';
import Roadmap from "../assets/roadmap.png";
import Compass from "../assets/compass.png";
import Refinery from "../assets/Refinery.png";
import "../styles/global.css"; 
---
<Layout pageTitle="Our Services">
    
<Header />
  <!-- Page: Services -->
  <section >
    <div class="text-center mb-12">
        <h1 class="text-4xl font-extrabold text-rivet-navy mb-4">Services Scaled for Your Business</h1>
        <p class="text-xl text-steel-blue max-w-3xl mx-auto">From a simple starting-point risk assessment to a comprehensive recovery plan, choose the level of support you need.</p>
    </div>
    <div class="displaycontainer">
        <div> <Image src={Refinery} alt="Image for Risk Refinery service" class="w-full h-48 object-cover rounded-md mb-4" /> </div>    
        <div> <Image src={Compass} alt="Image for Continuity Compass service" class="w-full h-48 object-cover rounded-md mb-4"/> </div>
        <div> <Image src={Roadmap} alt="Image for Rebound Roadmap service" class="w-full h-48 object-cover rounded-md mb-4" /> </div>
        <div>   
            <h2 class="text-2xl font-bold text-rivet-navy mb-3">Tier 1: Risk Refinery</h2>
            <p class="text-2xl font-bold text-steel-blue mb-4">$900</p>
            <p class="text-slate-600 mb-4">A fast, high-impact starting point to identify your key vulnerabilities.</p>
            <ul class="list-disc list-inside text-steel-blue mb-6">
                <li>2-hour on-site workshop</li>
                <li>Identify business-critical functions</li>
                <li>Pinpoint key weather vulnerabilities</li>
            </ul>
            <strong>Deliverable:</strong> A practical Risk Register you can use immediately.
        </div> 
        
        <div>
            <h2 class="text-2xl font-bold text-rivet-navy mb-3">Tier 2: Continuity Compass</h2>
                <p class="text-3xl font-bold text-steel-blue mb-4">$1,800</p>
                <p class="text-slate-600 mb-4">Our most popular package. Go from "what if" to "what to do".</p>
                <ul class="list-disc list-inside space-y-2 text-steel-blue mb-6">
                    <li>4-hour comprehensive workshop</li>
                    <li>Includes everything from Tier 1</li>
                    <li>Develop response & communication plans</li>
                    <li><strong>Deliverables:</strong> Risk Register + practical Disaster Management Plan.</li>
                </ul>
        </div>          
        
        <div>
            <h2 class="text-2xl font-bold text-rivet-navy mb-3">Tier 3: Rebound Roadmap</h2>
            <p class="text-3xl font-bold text-steel-blue mb-4">Project Pricing</p>
            <p class="text-slate-600 mb-4">Custom, hands-on support to help you recover and rebuild smarter after an event.</p>
            <ul class="list-disc list-inside space-y-2 text-steel-blue mb-6">
                <li>Post-event recovery support</li>
                <li>Insurance claim documentation help</li>
                <li>Supplier & premises relocation planning</li>
                <li><strong>Deliverable:</strong> Custom-scoped project to get you back in business.</li>
            </ul>
        </div>
    </div>
</section>
<Footer />        
</Layout>

<style>
.displaycontainer {
  display: grid;
  grid-template-columns: auto auto auto;
  padding: 10px;
}
.displaycontainer div {
  padding: 10px;
  font-size: 20px;
  text-align: left;
}


</style>