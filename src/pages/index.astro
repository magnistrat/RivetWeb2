---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/footer.astro";
import Header from "../components/header.astro";
import Hero from "../components/Hero.astro";
import { problem, solution } from "../content/content";
import Description from "../components/Description.astro";
---

<Layout>	
<Header />
    <Hero />
	<Description headline={problem.headline} description={problem.description} variant="primary" />
	<Description headline={solution.headline} description={solution.description} variant="secondary" />
<Footer />
</Layout>
