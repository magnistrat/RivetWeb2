---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/footer.astro";
import Header from "../components/header.astro";
import Button from "../components/starwind/button";
import { Resend } from 'resend';


const pageTitle = "Contact Us";

const baseKey:string = import.meta.env.RESEND_API_KEY;
const resend = new Resend(baseKey);

if (Astro.request.method === "POST") {
  try {
    const frmdata = await Astro.request.formData();
    const name = frmdata.get("name"); 
    const email = frmdata.get("email"); 
    const f_subject = frmdata.get("subject"); 
    const message = frmdata.get("message"); 
    
    const {data, error } = await resend.emails.send({
      from: 'Rivet <website@rivetrisk.com.au>',
      to: ['cchinner@rivetrisk.com.au'],
      subject: f_subject,
      html: "<h2>From: " + name + "</h2> <em>email: " + email +"</em><hr><p>" + message + "</p>",
    });
    return Astro.redirect("/");
  } catch (error) {
    if (error instanceof Error) {
      console.error("Error: - ", error.message);
    }
  }
}      

---
<Layout pageTitle>
  <Header />
  <main style="max-width: 600px; margin: 0 auto; padding: 2rem;">
      <h1>Contact Us</h1>
            <p>We'd love to hear about the risks that keep you awake at night. Fill out the form below and we'll get back to you shortly.</p>
    <form id="send-form" class="form" method="POST">
        <div class="form-group">
          <label for="name">Name</label>
          <input type="text" id="name" name="name" required />
        </div>

        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required />
        </div>

        <div class="form-group">
          <label for="subject">Subject</label>
          <input type="text" id="subject" name="subject" required />
        </div>

        <div class="form-group">
          <label for="message">Message</label>
          <textarea id="message" name="message" rows="5" required></textarea>
        </div>

        <Button id="submit-btn" type="submit">Send</button>
    </form>
  <div id="result" class="result" style="display: none;"></div>
  </main>
  <Footer /> 
</Layout> 

<style>
  .form-group { margin-bottom: 1rem; }
  .form-group label { display: block; margin-bottom: 0.5rem; font-weight: bold;}
  .form-group input, .form-group textarea { width: 100%; padding: 0.5rem; border: 1px solid #ccc; border-radius: 4px; }
  /* The honeypot field is hidden from real users but visible to screen-reading bots */
  .visually-hidden { position: absolute; left: -10000px; top: auto; width: 1px; height: 1px; overflow: hidden; }
  .status-message { margin-top: 1rem; padding: 1rem; border-radius: 4px; display: block; }
  .status-message.error { background: #f8d7da; color: #721c24; }
  .success-msg { background: #d4edda; color: #155724; display: block; margin-top: 1rem; padding: 1rem; border-radius: 4px; }
</style>



