---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/footer.astro";
import Header from "../components/header.astro";

const pageTitle = "Contact Us";
---
<Layout {pageTitle}>
  <Header />
  <main class="min-h-screen bg-gray-50 flex items-center justify-center p-4">
    <div class="w-full max-w-lg bg-white rounded-2xl shadow-xl p-8 transform transition-all duration-300 hover:shadow-2xl">  
    <div class="justify-center pl-50">
       <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="64" height="64" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
         <rect x="2" y="4" width="20" height="16" rx="2" />
          <polyline points="22,4 12,13 2,4" />
      </svg>   
    </div>

      <div class="pb-10">
      <h1>Contact Us</h1>
      <p>We'd love to hear about the risks that keep you awake at night. Fill out the form below and we'll get back to you shortly.</p>
      </div>
    <form
       action="https://formspree.io/f/mdkyjdwq"
      class="form"
      target="_top"
      method="POST"
    >
    <div class="field">
        <label class="label" for="email">Email</label>
        <input class="input " id="email" name="email" required />
      </div>
      <div class="field">
        <label class="label" for="message">Message</label>
        <textarea class="textarea" id="message" name="message"></textarea>
      </div>
      <div class="fs-button-group ">
        <button class="button" type="submit">Submit</button>
      </div>
    </form>
  </div>
  </main>
<Footer /> 
</Layout> 

<style>
 .form {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .field label {
    font-size: 0.875rem;
    font-weight: 500;
  }

  .field input,
  .field textarea {
    padding: var(--space-2) var(--space-3);
    background: #fff;
    border-width: 1px;
    border-color: var(--color-navy);
    border-radius: 5px;
  }

  .hint {
    font-size: 0.75rem;
    color: #999;
  }

  button[type='submit'] {
    padding: var(--space-2-5) var(--space-6);
    background: var(--rivet-orange);
    color: black;
    border: none;
    border-radius: 0.375rem;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
  }

  button[type='submit']:hover {
    opacity: 0.9;
  }

  button[type='submit']:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .result {
    padding: var(--space-4);
    border-radius: 0.375rem;
    margin-bottom: var(--space-8);
    font-size: 0.875rem;
  }

  .result.success {
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
    color: #166534;
  }

  .result.error {
    background: #fef2f2;
    border: 1px solid #fecaca;
    color: #991b1b;
  }

  .code-example {
    margin-top: var(--space-8);
  }

  .code-example h2 {
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: var(--space-4);
  }

  pre {
    background: #1a1a1a;
    color: #e5e5e5;
    padding: var(--space-4) var(--space-5);
    border-radius: 0.5rem;
    overflow-x: auto;
    font-size: 0.8125rem;
    line-height: 1.6;
  }
</style>



