---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/footer.astro";
import Header from "../components/header.astro";
export const prerender = false;

const pageTitle = "Contact Us";
---
<Layout {pageTitle}>
  <Header />
  <main class="min-h-screen bg-gray-50 flex items-center justify-center p-4">

    <div class="w-full max-w-lg bg-white rounded-2xl shadow-xl p-8 transform transition-all duration-300 hover:shadow-2xl">  
      <h1>Contact Us</h1>
            <p>We'd love to hear about the risks that keep you awake at night. Fill out the form below and we'll get back to you shortly.</p>
    <form id="send-form" class="form">

      <div class="field">
        <label for="name">Name</label>
        <input
          id="name"
          type="text"
          required
          placeholder="Your name"
          class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg text-gray-900 text-sm focus:outline-none focus:border-indigo-500 focus:bg-white focus:ring-4 focus:ring-indigo-100 transition-all duration-200"
        />
      </div>

      <div class="field">
      <label for="from">Email</label>
      <input
        id="from"
        type="email"
        value=""
        required
        placeholder="Email address"
        class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg text-gray-900 text-sm focus:outline-none focus:border-indigo-500 focus:bg-white focus:ring-4 focus:ring-indigo-100 transition-all duration-200"
      />
    </div>

    <div class="field">
      <label for="message">How can we help you?</label>
      <textarea id="message" rows={4} required class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg text-gray-900 text-sm focus:outline-none focus:border-indigo-500 focus:bg-white focus:ring-4 focus:ring-indigo-100 transition-all duration-200"></textarea>
    </div>

    <button type="submit" id="submit-btn">Send Email</button>
  </form>

  <div id="result" class="result" style="display: none;"></div>
  </div>
  </main>
<Footer /> 
</Layout> 


<script>
  const form = document.getElementById('send-form') as HTMLFormElement;
  const btn = document.getElementById('submit-btn') as HTMLButtonElement;
  const resultDiv = document.getElementById('result') as HTMLDivElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.disabled = true;
    btn.textContent = 'Sending...';
    resultDiv.style.display = 'none';

    const from = (document.getElementById('from') as HTMLInputElement).value;
    const name = (document.getElementById('name') as HTMLInputElement).value;
    const message = (document.getElementById('message') as HTMLTextAreaElement).value;
    const subject = "Web Contact Form"
    const mailto = "";
    const mode = "SEND"
     try {
      const response = await fetch('/api/send', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ mode, name, from, subject, mailto, message }),
      });
   
      const data = await response.json();
      resultDiv.style.display = 'block';

      if (!response.ok) {
        resultDiv.className = 'result error';
        resultDiv.textContent = data.error || 'Failed to send email';
      } else {
        resultDiv.className = 'result success';
        resultDiv.innerHTML = `<strong>Thanks for making contact. We'll be in touch soon.</strong>`;
      }
    } catch {
      resultDiv.style.display = 'block';
      resultDiv.className = 'result error';
      resultDiv.textContent = 'Network error. Please try again.';
    } finally {
      btn.disabled = false;
      btn.textContent = 'Send Email';
    }
  });
</script>


<style>
 .form {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .field label {
    font-size: 0.875rem;
    font-weight: 500;
  }

  .field input,
  .field textarea {
    padding: var(--space-2) var(--space-3);
    background: #fff;
  }

  .hint {
    font-size: 0.75rem;
    color: #999;
  }

  button[type='submit'] {
    padding: var(--space-2-5) var(--space-4);
    background: #1a1a1a;
    color: #fff;
    border: none;
    border-radius: 0.375rem;
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
  }

  button[type='submit']:hover {
    opacity: 0.9;
  }

  button[type='submit']:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .result {
    padding: var(--space-4);
    border-radius: 0.375rem;
    margin-bottom: var(--space-8);
    font-size: 0.875rem;
  }

  .result.success {
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
    color: #166534;
  }

  .result.error {
    background: #fef2f2;
    border: 1px solid #fecaca;
    color: #991b1b;
  }

  .code-example {
    margin-top: var(--space-8);
  }

  .code-example h2 {
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: var(--space-4);
  }

  pre {
    background: #1a1a1a;
    color: #e5e5e5;
    padding: var(--space-4) var(--space-5);
    border-radius: 0.5rem;
    overflow-x: auto;
    font-size: 0.8125rem;
    line-height: 1.6;
  }
</style>



