---
export const prerender = false;
---

<!-- Button to trigger the modal -->
<div class="flex justify-center">
  <button id="open-btn" class="open-btn">Download your free toolkit</button>
</div>
<!-- The dialog element -->
<dialog id="popup-dialog" class="popup-dialog">
  <div class="mx-auto relative max-w-sm rounded-xl bg-white p-6 shadow-lg outline outline-black/5">
    <button id="close-btn" class="close-btn absolute top-3 right-3" aria-label="Close">×</button>
    <div class="flex flex-col items-center gap-3 text-center">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="64" height="64" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <rect x="2" y="4" width="20" height="16" rx="2"></rect>
      <polyline points="22,4 12,13 2,4"></polyline>
    </svg>

      <h3 class="m-0 text-lg text-[#0A2342]">Get the free toolkit</h3>
      <p class="m-0 text-gray-600 max-w-xs">Sign up to get the Master Emergency Checklist and SEQ Risk Management Resource Guide</p>
    </div>
    <div class="mt-4 bg-gray-50 p-3 rounded-md">
      <form id="CTA-form" class="flex flex-col gap-2" autocomplete="on">
        <div>
          <input type="email" id="email-input" class="form-input w-full px-3 py-2 rounded-md border border-gray-200" placeholder="Email address" required />
        </div>  
        <button type="submit" class="submit-btn open-btn px-4 py-2 rounded-md">Get the free kit</button>
      </form>
      <div id="result" class="mt-3 hidden text-sm" style="display: none;"></div>
    </div>
  </div>
</dialog>


<script>
  const dialog = document.getElementById('CTA-form') as HTMLDialogElement;
  const openBtn = document.getElementById('open-btn');
  const closeBtn = document.getElementById('close-btn');
  const resultDiv = document.getElementById('result') as HTMLDivElement;

  // Trigger default dialog actions
  openBtn?.addEventListener('click', () => {dialog.showModal(); console.log("open")});
  closeBtn?.addEventListener('click', () => dialog.close());
  dialog.addEventListener('click', (event) => {if (event.target === dialog) {dialog.close();}});
 
  dialog.addEventListener('submit', async (event) => {
      event.preventDefault();
      const email = (document.getElementById('email-input') as HTMLInputElement).value;
       if (!email) {
        resultDiv.style.display = 'block';
        resultDiv.className = 'mt-3 text-sm text-red-600';
        resultDiv.textContent = 'Please enter an email address.';
        return;
      }
      console.log("email captured ->", email);
      closeBtn.setAttribute('disabled', 'true');
      resultDiv.style.display = 'none';
      //= first save the addres to Resend
      try {
        const response = await fetch('/api/contacts', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });

        const data = await response.json();
        resultDiv.style.display = 'block';

        if (!response.ok) {
          resultDiv.className = 'mt-3 text-sm text-red-600';
          resultDiv.textContent = data.error || 'Failed to send email';
        } else {
          resultDiv.className = 'mt-3 text-sm text-green-600';
          resultDiv.innerHTML = '<strong>Thanks! Now check your email</strong><p>You should get a confirmation email soon, <strong>open it up</strong> and <strong>confirm your email</strong> so we can keep you up to date.</p>';
        }
      } catch {
        resultDiv.style.display = 'block';
        resultDiv.className = 'mt-3 text-sm text-red-600';
        resultDiv.textContent = 'Network error. Please try again.';
      } finally {
        closeBtn.removeAttribute('disabled');
      }
      //== Then send the confirmation email 
    });

</script>


<style>
  /* Button Styling */
  .open-btn {
    padding: var(--space-3) var(--space-10);
    background-color: var(--rivet-orange);
    color: white;
    border: none;
    border-radius: 6px;
    font-size: 1.2rem;
    cursor: pointer;
    transition: background-color 0.2s;
  }
  .open-btn:hover { background-color: var(--secondary); color: var(--rivet-navy)}

  /* Dialog (Backdrop) Styling */
  .popup-dialog {
    top:20%;
    left:35%;
    border: none;
    border-radius: 18px;
    padding: 0;
    max-width: 500px;
    width: 100%;
    background: transparent; /* Allows custom shadow and backdrop styling */
    backdrop-filter: blur(5px);
  }
  
  .popup-dialog::backdrop {
    background: rgba(0, 0, 0, 0.5);
  }

  /* Modal Container */
  .modal-content {
    background: white;
    padding: var(--space-8);
    border-radius: 12px;
    position: relative;
    box-shadow: 0 10px 25px rgba(0,0,0,0.1);
  }

  /* Close Button */
  .close-btn {
    background: none;
    border: none;
    font-size: 1.5rem;
    cursor: pointer;
    color: #6b7280;
  }
  .close-btn:hover { color: #111827; }
</style>
