---
import Navigation from "./Navigation.astro";
import Logo from "./Logo.astro";
---

<header class={`sticky top-0 w-full bg-gray-50`} >
	<div class="px-4 sm:px-6 lg:px-8 border-b-2 border-indigo-900">
		<div class="flex h-16 items-center md:h-20">
			<!-- Logo -->
			<div>
				<a href="/" class="flex-none w-15">
					<Logo height={45} />
				</a>
			</div>
			<!-- Navigation Links -->
			 <div>
				<nav class="hidden md:flex items-center gap-10 ">
				<Navigation />
				</nav>
			 </div>	
		</div>	
	</div>
</header>



<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		width: 100%;
		border-bottom: 5px solid var(--burnt-orange);
		backdrop-filter: blur(8px);
	}

	h2 {
		margin: 0;
		font-size: 1.125rem;
		font-weight: 700;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
		color: var(--text-primary);
		font-weight: 700;
	}
	
	nav {
		max-width: 1200px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 64px;
		padding: 0 1rem;
	}
	
	.nav-left {
		flex-shrink: 0;
	}
	
	.nav-center {
		display: flex;
		gap: 2rem;
	}
	
	.nav-right {
		display: flex;
		gap: 0.5rem;
		position: relative;
	}
	
	.nav-btn {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 36px;
		height: 36px;
		border: none;
		background: none;
		border-radius: 0.5rem;
		color: var(--color-neutral-950);
		cursor: pointer;
		transition: all 0.2s ease;
	}
	
	.nav-btn:hover {
		background-color: var(--bg-secondary);
		color: var(--accent);
	}
	


</style>