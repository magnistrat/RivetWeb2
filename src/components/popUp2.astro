---
// src/components/Dialog.astro
interface Props {
  id: string;
  title: string;
}

const { id, title } = Astro.props;
---

<dialog id={id} class="popup-dialog">
  
</dialog>


<script>
  // This script runs ONCE on the client, managing all dialogs on the page
  const dialogs = document.querySelectorAll<HTMLDialogElement>('dialog.popup-dialog');
  console.log(dialogs);  

  dialogs.forEach((dialog) => {
    const cancelBtn = dialog.querySelector('[data-action="cancel"]');
    const confirmButton = dialog.querySelector('[data-action="confirm"]');

    // Handle Cancel / Close
    cancelBtn?.addEventListener('click', () => {
      dialog.close();
    });

    // Handle Confirm Click

    confirmButton?.addEventListener('click', () => {
      // 1. Create a custom event unique to this action
      const confirmEvent = new CustomEvent('dialog-confirmed', {
        bubbles: true, // Allows it to be listened to on the dialog element itself
      });
      console.log("Confirmed")
      // 2. Dispatch the event
      dialog.dispatchEvent(confirmEvent);
      
      // 3. Close the dialog
      dialog.close();
    });
  });
</script>

<style>
  /* Basic Backdrop Styling */
  .popup-dialog {
    top:20%;
    left:35%;
    border: none;
    border-radius: 18px;
    padding: 0;
    max-width: 500px;
  }
  popup-dialog::backdrop {
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
 
  }
 
  /* Modal Container */
  .dialog-content {
    background: white;
    padding: var(--space-8);
    border-radius: 12px;
    position: relative;
    box-shadow: 0 10px 25px rgba(0,0,0,0.1);
  }

  /* Close Button */
  .close-btn {
    background: none;
    border: none;
    font-size: 1.5rem;
    cursor: pointer;
    color: #6b7280;
  }
  .close-btn:hover { color: #111827; } 
</style>